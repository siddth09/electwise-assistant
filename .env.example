# ElectWise AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────
# Get your free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Google Custom Search (live election news) ───────────────────────
# Create a Programmable Search Engine at: https://programmablesearchengine.google.com
# Get the API key at: https://console.cloud.google.com/apis/credentials
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# ── Application Settings ───────────────────────────────────────────────────────
FLASK_ENV=development       # Use 'production' for Cloud Run deployment
SECRET_KEY=change-me-to-a-strong-random-string
PORT=8080
